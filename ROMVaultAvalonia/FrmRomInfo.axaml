<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ROMVault.FrmRomInfo"
        Title="ROM Info"
        Width="500" Height="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource RvBgBrush}">
    <TextBox x:Name="textBox1" Margin="8"
             IsReadOnly="True" AcceptsReturn="True"
             TextWrapping="Wrap"
             Background="{DynamicResource RvBgBrush0}"
             Foreground="{DynamicResource RvFgBrush}"/>
</Window>
